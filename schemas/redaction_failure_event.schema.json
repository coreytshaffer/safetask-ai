{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Redaction Failure Event",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "export_request_id": {
      "type": "string"
    },
    "source_event_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "redaction_status": {
      "type": "string",
      "enum": [
        "redaction_review_required",
        "redaction_failed_export_blocked"
      ]
    },
    "export_allowed": {
      "type": "boolean"
    },
    "failure_reason": {
      "type": "string"
    },
    "required_human_review": {
      "type": "boolean"
    },
    "source_frame_retention_until": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "schema_version",
    "export_request_id",
    "source_event_id",
    "created_at",
    "redaction_status",
    "export_allowed",
    "failure_reason",
    "required_human_review",
    "source_frame_retention_until"
  ],
  "if": {
    "properties": {
      "redaction_status": { "const": "redaction_failed_export_blocked" }
    },
    "required": ["redaction_status"]
  },
  "then": {
    "properties": {
      "export_allowed": { "const": false }
    }
  },
  "not": {
    "anyOf": [
      { "required": ["plate_text"] },
      { "required": ["license_plate"] },
      { "required": ["ocr_text"] },
      { "required": ["face_id"] },
      { "required": ["face_embedding"] },
      { "required": ["person_id"] },
      { "required": ["track_id"] },
      { "required": ["vehicle_id"] },
      { "required": ["recognized_identity"] },
      { "required": ["unredacted_image_data"] }
    ]
  },
  "additionalProperties": false
}
