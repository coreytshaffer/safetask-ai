{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flame Smoke Claim",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "source_event_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "possible_flame",
        "possible_smoke",
        "ambiguous_fire_signature"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "frame_reference": {
      "type": "string"
    },
    "hazard_region": {
      "type": "object",
      "properties": {
        "bbox": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 4,
          "maxItems": 4,
          "description": "Pixel coordinates [x_min, y_min, x_max, y_max] from top-left origin. x_min < x_max, y_min < y_max."
        },
        "polygon": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "region_type": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "anyOf": [
        { "required": ["bbox"] },
        { "required": ["polygon"] }
      ]
    },
    "review_required": {
      "type": "boolean",
      "const": true
    },
    "export_allowed": {
      "type": "boolean",
      "default": false
    },
    "retention": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "source_event_id",
    "source_id",
    "captured_at",
    "claim_type",
    "confidence",
    "frame_reference",
    "hazard_region",
    "review_required",
    "export_allowed"
  ],
  "additionalProperties": false
}
