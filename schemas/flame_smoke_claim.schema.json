{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flame Smoke Claim",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "source_event_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "possible_flame",
        "possible_smoke",
        "ambiguous_fire_signature"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "frame_reference": {
      "type": "string"
    },
    "hazard_region": {
      "type": "object"
    },
    "review_required": {
      "type": "boolean",
      "const": true
    },
    "export_allowed": {
      "type": "boolean",
      "default": false
    },
    "retention": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "source_event_id",
    "source_id",
    "captured_at",
    "claim_type",
    "confidence",
    "frame_reference",
    "hazard_region",
    "review_required",
    "export_allowed"
  ],
  "additionalProperties": false
}
